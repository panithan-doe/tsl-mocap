# Thai Sign Language Translator - Environment Variables
# Copy this file to .env and fill in your actual values

# Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare R2 Storage Base URL
# This is the public URL for your R2 bucket where motion.json files are stored
CLOUDFLARE_R2_BASE_URL=https://your-bucket-url.r2.dev
