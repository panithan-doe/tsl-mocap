# Thai Sign Language Translator - Environment Variables
# Copy this file to .env and fill in your actual values

# Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare R2 Storage Base URL
# This is the public URL for your R2 bucket where motion.json files are stored
CLOUDFLARE_R2_BASE_URL=https://your-bucket-url.r2.dev

# Motion Storage Configuration
# Set to 'local' to use local HTTP server, 'r2' to use Cloudflare R2 (default: r2)
MOTION_STORAGE_MODE=r2

# Local server URL for MOTION_DICT (required when MOTION_STORAGE_MODE=local)
# Run: cd /path/to/cs-project-mocap && python3 -m http.server 8080
# Then set: MOTION_LOCAL_PATH=http://localhost:8080/MOTION_DICT
MOTION_LOCAL_PATH=

# Backend API URL for adding new words
# Local development: http://localhost:8000
# Production: https://your-backend.railway.app
BACKEND_API_URL=http://localhost:8000
